# ─── Sanity ───────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage after creating your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Used for server-side operations (ISR revalidation, mutations)
# Create a token at https://sanity.io/manage → API → Tokens
SANITY_API_TOKEN=your_token_here

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://plavi.studio
